{
  "ConnectionStrings": {
    "Default": "Data Source=auth.db"
  },
  "Jwt": {
    "Issuer":        "https://authapi.local",
    "Audience":      "https://authapi.local/resources",
    "ExpiryMinutes": "60",
    "EcdsaKeyPath":  "ecdsa-key.pem"
  },
  "Logging": {
    "LogLevel": {
      "Default":                       "Information",
      "Microsoft.AspNetCore":          "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
